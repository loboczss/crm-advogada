# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=sb_publishable_your_anon_key_here
SUPABASE_SECRET_KEY=sb_secret_your_service_role_key_here

# N8N / Webhooks
N8N_RAG_WEBHOOK_URL=https://your-n8n.domain/webhook/your-webhook-id

# OpenAI
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Dropbox
DROPBOX_CLIENT_ID=your_dropbox_app_client_id
DROPBOX_CLIENT_SECRET=your_dropbox_app_client_secret
DROPBOX_REFRESH_TOKEN=your_dropbox_refresh_token

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key_here
MAILER_SENDER_EMAIL=Your App <noreply@yourdomain.com>

# Public URLs
NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_PUBLIC_ORIGINAL_SITE_URL=https://www.yourdomain.com

# RapidAPI (Booking.com)
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=booking-com15.p.rapidapi.com
